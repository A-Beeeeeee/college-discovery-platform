// Prisma schema — College Discovery Platform
// WHY: Normalized relational model matches college ↔ courses ↔ reviews domain.
// Slug on College enables SEO-friendly URLs (/colleges/iit-bombay).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth models (required by @auth/prisma-adapter) ─────────────────────

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  reviews       Review[]
  savedColleges SavedCollege[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain models ───────────────────────────────────────────────────────────

enum CollegeType {
  GOVERNMENT
  PRIVATE
  DEEMED
}

enum FeeCategory {
  TUITION
  HOSTEL
  OTHER
}

model College {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  shortName     String?
  description   String         @db.Text
  city          String
  state         String
  country       String         @default("India")
  type          CollegeType
  established   Int?
  website       String?
  logoUrl       String?
  coverImageUrl String?
  avgRating     Float          @default(0)
  reviewCount   Int            @default(0)
  totalStudents Int?
  campusSize    String?
  accreditation String?
  courses       Course[]
  fees          CollegeFee[]
  placements    Placement[]
  reviews       Review[]
  savedBy       SavedCollege[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([state])
  @@index([city])
  @@index([type])
  @@index([avgRating])
  @@index([name])
}

model Course {
  id          String  @id @default(cuid())
  collegeId   String
  name        String
  degree      String
  duration    String
  feesPerYear Int
  seats       Int?
  college     College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model CollegeFee {
  id        String      @id @default(cuid())
  collegeId String
  category  FeeCategory
  label     String
  amount    Int
  period    String      @default("per year")
  college   College     @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model Placement {
  id              String   @id @default(cuid())
  collegeId       String
  year            Int
  highestPackage  Float?
  averagePackage  Float?
  medianPackage   Float?
  placementRate   Float?
  topRecruiters   String[]
  college         College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([collegeId, year])
  @@index([collegeId])
}

model Review {
  id        String   @id @default(cuid())
  collegeId String
  userId    String
  rating    Int
  title     String?
  content   String   @db.Text
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([collegeId])
  @@index([userId])
}

model SavedCollege {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, collegeId])
  @@index([userId])
}
